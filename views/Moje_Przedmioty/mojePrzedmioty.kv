#:import ButtonStyle Style.ButtonStyle.ButtonStyle
#:import get_color_from_hex kivy.utils.get_color_from_hex



<DashboardBrick>:
    size_hint: 1, None
    height: dp(120)
    on_release: app.change_screen('subjectDetails', selectedSubject=self.subject_obj)
    
    padding: 0
    spacing: 0

    RelativeLayout:
        size_hint: 1, 1
        Widget:
            size_hint: 1, 1
            canvas:
                StencilPush
                RoundedRectangle:
                    pos: 0, 0
                    size: self.size
                    radius: [root.style.border_radius] if root.style else [dp(20)]
                StencilUse
                
                # B. Rysowanie obrazka bezpośrednio na płótnie
                Color:
                    rgba: 1, 1, 1, 0.1 # Opacity (Przezroczystość)
                Rectangle:
                    source: 'Images/notebook.png'
                    size: self.height * 1.5, self.height * 1.5
                    # x = krawędź minus 60%, y = wyśrodkowanie pionowe
                    pos: self.width - (self.height * 1.5 * 0.6), (self.height - (self.height * 1.5)) / 2
                

                StencilUnUse
                RoundedRectangle:
                    pos: 0, 0
                    size: self.size
                    radius: [root.style.border_radius] if root.style else [dp(20)]
                StencilPop
                
        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 1
            padding: dp(15)
            spacing: dp(5)

            Label:
                text: root.subject_obj.title if root.subject_obj else ""
                bold: True
                color: get_color_from_hex(root.style.text_color) if root.style else app.theme.DefaultColors.DEFAULT_BLACK
                
                text_size: self.width, None
                shorten: True
                shorten_from: 'right'
                
                halign: 'left'
                valign: 'top'
                font_size: max(sp(16), min(root.width * 0.07, sp(26)))

            Label:
                text: root.subject_obj.teacher if root.subject_obj else ""
                color: get_color_from_hex(root.style.text_color) if root.style else app.theme.DefaultColors.DEFAULT_BLACK
                
                # ZMIANA: To samo dla nazwiska prowadzącego
                text_size: self.width, None
                shorten: True
                shorten_from: 'right'
                
                halign: 'left'
                valign: 'middle'
                font_size: max(sp(12), min(root.width * 0.045, sp(18)))

            Label:
                text: app.translate(f"my_subject_{root.subject_obj.status}", app.language) if root.subject_obj else ""
                bold: True
         
                color: get_color_from_hex(root.style.text_color) if root.style else app.theme.DefaultColors.DEFAULT_BLACK
                text_size: self.size
                halign: 'left'
                valign: 'bottom'
                font_size: max(sp(10), min(root.width * 0.04, sp(14)))

<SubjectGreen>:
    status_text: app.translate('my_subject_completed' , app.language)
    style: ButtonStyle(bg_color=app.theme.SubjectColors.SUBJECT_BG_COLOR_COMPLETED, text_color=app.theme.SubjectColors.SUBJECT_TEXT_COLOR_DARK, border_radius=10)

<SubjectRed>:
    status_text: app.translate('my_subject_atrisk' , app.language)
    style: ButtonStyle(bg_color=app.theme.SubjectColors.SUBJECT_BG_COLOR_ATRISK, text_color=app.theme.SubjectColors.SUBJECT_TEXT_COLOR_DARK, border_radius=10)

<SubjectWhite>:
    status_text: app.translate('my_subject_inprogress' , app.language)
    style: ButtonStyle(bg_color=app.theme.SubjectColors.SUBJECT_BG_COLOR_INPROGRESS, text_color=app.theme.SubjectColors.SUBJECT_TEXT_COLOR_DARK, border_radius=10)

<SubjectBlack>:
    status_text: app.translate('my_subject_failed' , app.language)
    style: ButtonStyle(bg_color=app.theme.SubjectColors.SUBJECT_BG_COLOR_FAILED, text_color=app.theme.SubjectColors.SUBJECT_TEXT_COLOR_BRIGHT, border_radius=10)
    
<MojePrzedmiotyScreen>:
    BoxLayout:
        
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        
        # Ciemnoszare tło całej aplikacji (jak na screenie poza niebieskim obszarem)

        # Nagłówek
        Label:
            text: app.translate("my_subjects_text", app.language)
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: dp(40)
            text_size: self.size
            halign: 'left'
            valign: 'middle'

        # Niebieski kontener na kafelki
        BoxLayout:
            padding: dp(15)
            canvas.before:
                Color:
                    rgba: get_color_from_hex(app.theme.UiColors.SECONDARY_BG_COLOR)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10,]

            # Siatka, która automatycznie układa kafelki od lewej do prawej
            ScrollView:
                do_scroll_x: False
                scroll_timeout: 0
                scroll_distance: dp(5)
                GridLayout:
                    id: grid_przedmiotow
                    cols: 3 # Ilość kolumn (dostosuj do szerokości okna)
                    spacing: dp(15)
                    
                    # Ważne: to pozwala siatce rosnąć w dół, jeśli dodasz więcej kafelków
                    size_hint_y: None
                    height: self.minimum_height
