#:import ButtonStyle Style.ButtonStyle.ButtonStyle
#:import Shapes Widgets.Button.Shapes
#:import get_color_from_hex kivy.utils.get_color_from_hex

<DashboardBrick>:
    size_hint: 1, None
    height: dp(120)
    on_release: app.change_screen('subjectDetails', selectedSubject=self.subject_obj)
    
    padding: 0
    spacing: 0

    RelativeLayout:
        size_hint: 1, 1

        Image:
      
            source: 'Images/notebook.png' 
            opacity: 0.1
            allow_stretch: True
            keep_ratio: True 
            
            size_hint: None, None
            height: root.height * 1.5
            width: self.height
          

            # Odejmowanie self.width * 0.6 oznacza, że 60% obrazka
            # jest widoczne, a 40% wylatuje "za burtę" z prawej strony.
            x: root.width - (self.width * 0.6)
            
            center_y: root.height / 2
        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 1
            padding: dp(15)
            spacing: dp(5)

            Label:
                text: root.subject_obj.title if root.subject_obj else ""
                bold: True
                color: get_color_from_hex(root.style.text_color) if root.style else [0,0,0,1]
                
                text_size: self.width, None
                shorten: True
                shorten_from: 'right'
                
                halign: 'left'
                valign: 'top'
                font_size: max(sp(16), min(root.width * 0.07, sp(26)))

            Label:
                text: root.subject_obj.teacher if root.subject_obj else ""
                color: get_color_from_hex(root.style.text_color) if root.style else [0,0,0,1]
                
                # ZMIANA: To samo dla nazwiska prowadzącego
                text_size: self.width, None
                shorten: True
                shorten_from: 'right'
                
                halign: 'left'
                valign: 'middle'
                font_size: max(sp(12), min(root.width * 0.045, sp(18)))

            Label:
                text: app.translate(f"my_subject_{root.subject_obj.status}", app.language) if root.subject_obj else ""
                bold: True
         
                color: get_color_from_hex(root.style.text_color) if root.style else [0,0,0,1]
                text_size: self.size # Status zwykle jest krótki, tu wystarczy self.size
                halign: 'left'
                valign: 'bottom'
                font_size: max(sp(10), min(root.width * 0.04, sp(14)))

<SubjectGreen@DashboardBrick>:
    status_text: app.translate('my_subject_completed' , app.language)
    style: ButtonStyle(bg_color="#62c57b", text_color="000000", border_radius=10, shape=Shapes.ROUNDED)

<SubjectRed@DashboardBrick>:
    status_text: app.translate('my_subject_atrisk' , app.language)
    style: ButtonStyle(bg_color="#f28b82", text_color="000000", border_radius=10, shape=Shapes.ROUNDED)

<SubjectWhite@DashboardBrick>:
    status_text: app.translate('my_subject_inprogress' , app.language)
    style: ButtonStyle(bg_color="#d9d9d7", text_color="000000", border_radius=10, shape=Shapes.ROUNDED)

<SubjectBlack@DashboardBrick>:
    status_text: app.translate('my_subject_failed' , app.language)
    style: ButtonStyle(bg_color="#272724", text_color="ffffff", border_radius=10, shape=Shapes.ROUNDED)
    
<MojePrzedmiotyScreen@Screen>
    BoxLayout:
        
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        
        # Ciemnoszare tło całej aplikacji (jak na screenie poza niebieskim obszarem)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#332b2b")
            Rectangle:
                pos: self.pos
                size: self.size

        # Nagłówek
        Label:
            text: app.translate("my_subjects_text", app.language)
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: dp(40)
            text_size: self.size
            halign: 'left'
            valign: 'middle'

        # Niebieski kontener na kafelki
        BoxLayout:
            padding: dp(15)
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#1c4271") # Niebieskie tło
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10,]

            # Siatka, która automatycznie układa kafelki od lewej do prawej
            ScrollView:
                do_scroll_x: False

                GridLayout:
                    id: grid_przedmiotow
                    cols: 3 # Ilość kolumn (dostosuj do szerokości okna)
                    spacing: dp(15)
                    
                    # Ważne: to pozwala siatce rosnąć w dół, jeśli dodasz więcej kafelków
                    size_hint_y: None
                    height: self.minimum_height
