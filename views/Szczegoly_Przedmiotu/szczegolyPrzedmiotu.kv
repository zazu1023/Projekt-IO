
#:import get_color_from_hex kivy.utils.get_color_from_hex
#:import ButtonStyle Style.ButtonStyle.ButtonStyle
#:import ButtonState Style.ButtonState.ButtonState


<BackButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#c0c2c4", text_color="#000000", border_radius=8)
    size_hint: 1, 1

<SuccessButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#2ecc71", text_color="#000000", border_radius=6, border_color="#ffffff", border_width=2)
    size_hint: 1, 1


<WarningButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#f1c40f", text_color="#000000", border_radius=6)
    size_hint: 1, 1

<DangerButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#e74c3c", text_color="#000000", border_radius=6)
    size_hint: 1, 1

<FailedButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#272724", text_color="#ffffff", border_radius=6)
    size_hint: 1, 1
  



<PrimaryButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#114c85", text_color="#ffffff", border_radius=10)

<MinusButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#c0392b", text_color="#ffffff", border_radius=8)
    radius: [dp(8)]

<PlusButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="#2980b9", text_color="#ffffff", border_radius=8)
    radius: [dp(8)]

# ========================================================
# 2. SZABLON: Ciemne pole tekstowe
# ========================================================
<DarkRoundedInput@TextInput>:
    background_normal: ''
    background_color: get_color_from_hex("#322d2d") # Ciemne tło pola
    foreground_color: 1, 1, 1, 1 # Biały tekst
    cursor_color: 1, 1, 1, 1
    size_hint_y: None
    height: dp(35)
    multiline: False
    padding_y: [self.height / 2.0 - (self.line_height / 2.0), 0] # Wyśrodkowanie tekstu w pionie
# ========================================================
# 3. GŁÓWNY WIDOK EKRANU
# ========================================================
<SzczegolyPrzedmiotuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(20)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#3b3232")
            Rectangle:
                pos: self.pos
                size: self.size

        # --- GÓRNY PASEK ---
        BoxLayout:
            orientation: 'vertical'  # Układa elementy jeden pod drugim
            size_hint_y: None
            height: dp(80)           # Zwiększona wysokość, bo mamy dwa wiersze
            spacing: dp(10)          # Odstęp między tytułem a przyciskiem
            
            Label:
                text: f"{app.translate('subject_details_title',app.language)}: {root.selectedSubject.title if root.selectedSubject else ''}"
                font_size: '28sp'    # Troszkę większa czcionka, jak na makiecie
                bold: True
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            BackButton:
                text: app.translate('back_button' , app.language)
                size_hint: None, None
                size: dp(90), dp(35)
                pos_hint: {'x': 0}   # Przykleja przycisk mocno do lewej krawędzi!
                on_release: app.change_screen('mySubjects')

        # --- GŁÓWNA ZAWARTOŚĆ ---
        BoxLayout:
            spacing: dp(20)
            
            # --- LEWA KOLUMNA ---
            ScrollView:
                do_scroll_x: False
                size_hint_x: 0.5
                bar_width: dp(8)
                bar_color: get_color_from_hex("#888888")
                bar_inactive_color: get_color_from_hex("#666666")
                
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(15)
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [0, 0, dp(10), 0]
                    
                    # 1. PANEL STATUSU
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(135) # Lekko powiększony, by przyciski oddychały
                        padding: dp(15)
                        spacing: dp(10)
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#063e6e")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12)]
                                
                        Label:
                            text: app.translate('current_status' , app.language)
                            bold: True
                            font_size: '18sp'
                            size_hint_y: None
                            height: dp(20)
                            text_size: self.size
                            halign: 'left'
                            
                        Label:
                            text: app.translate('my_subject_' + root.selectedSubject.status , app.language) if root.selectedSubject else app.translate('my_subject_completed', app.language)
                            color: root.get_status_color(root.selectedSubject.status if root.selectedSubject else 'unknown')
                            bold: True
                            size_hint_y: None
                            height: dp(20)
                            text_size: self.size
                            halign: 'left'
                            
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(35) 
                            # Przyciski wypełnią tę przestrzeń, bo dostały size_hint: 1, 1
                            SuccessButton:
                                state: 'down' if root.selectedSubject and root.selectedSubject.status == self.text else 'normal'
                                text: app.translate('my_subject_completed', app.language)
                                on_release: root.change_status('completed')
                            WarningButton:
                                state: 'down' if root.selectedSubject and root.selectedSubject.status == self.text else 'normal'
                                text: app.translate('my_subject_inprogress', app.language)
                                on_release: root.change_status('inprogress')
                            DangerButton:
                                state: 'down' if root.selectedSubject and root.selectedSubject.status == self.text else 'normal'
                                text: app.translate('my_subject_atrisk', app.language)
                                on_release: root.change_status('atrisk')
                            FailedButton:
                                state: 'down' if root.selectedSubject and root.selectedSubject.status == self.text else 'normal'
                                text: app.translate('my_subject_failed', app.language)
                                on_release: root.change_status('failed')

                    # 2. PANEL NIEOBECNOŚCI
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(130)
                        padding: dp(15)
                        spacing: dp(10)
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#063e6e")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12)]
                                
                        Label:
                            text: app.translate('absences' , app.language)
                            bold: True
                            size_hint_y: None
                            font_size: '18sp'
                            height: dp(20)
                            text_size: self.size
                            halign: 'left'
                            
                        Label:
                            
                            text: str(root.selectedSubject.absences) + "/" + str(root.selectedSubject.max_absences) if root.selectedSubject else "1/2"
                            font_size: '34sp'
                            bold: True
                            size_hint_y: None
                            height: dp(35)
                            text_size: self.size
                            halign: 'left'
                            
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30) 
                            
                            MinusButton:
                                text: "-"
                                size_hint: None, 1
                                width: dp(40) # Kwadratowy mały przycisk
                                on_release: root.change_absences(-1)
                            PlusButton:
                                text: "+"
                                size_hint: None, 1
                                width: dp(40) # Kwadratowy mały przycisk
                                on_release: root.change_absences(1)
                            Widget:

                    # 3. PANEL EDYCJI
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(460) 
                        padding: dp(15)
                        spacing: dp(8) 
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#063e6e")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12)]
                                
                        Label:
                            text: app.translate('edit_subject' , app.language)
                            bold: True
                            font_size: '18sp'
                            color: get_color_from_hex("#ffffff") # Upewniamy się, że jest czysto biała
                            size_hint_y: None
                            height: dp(40)         # Zwiększona wysokość, by zmieścić duży tekst
                            text_size: self.size
                            halign: 'left'
                            valign: 'middle'
                            
            
                        Label:
                            text: app.translate('subject_name' , app.language)
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_title

                        Label:
                            text: app.translate('teacher' , app.language)
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_teacher
                        
                        Label:
                            text: app.translate('passing_conditions' , app.language)
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_conditions

                        Label:
                            text: app.translate('max_absences' , app.language)
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_max_absences
                            
                        Label:
                            text: app.translate('max_pluses' , app.language)
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_max_pluses
                        Label:
                            text: app.translate('max_colloqium_pluses' , app.language)
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_max_colloquium_pluses
                            
                        Widget: 

            # --- PRAWA KOLUMNA (Notatka) ---
            BoxLayout:
                orientation: 'vertical'
                padding: dp(15)
                spacing: dp(15)
                size_hint_x: 0.5
                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#063e6e")
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]

                Label:
                    text: app.translate('general_note' , app.language)
                    bold: True
                    font_size: '18sp'
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
                
                TextInput:
                    id: input_note
                    multiline: True
                    background_color: get_color_from_hex("#e0e0e0") # Jasnoszare tło z docelowego
                    text: (root.selectedSubject.note or "") if root.selectedSubject else ""
                    
                PrimaryButton:
                    text: app.translate('save_changes' , app.language)
                    size_hint: 1, None 
                    height: dp(40)
                    on_release:
                        root.save_changes() 
                       