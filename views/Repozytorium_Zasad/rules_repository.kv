#:import get_color_from_hex kivy.utils.get_color_from_hex

<SubjectCard>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(250) # Nieco wyższa, by pomieścić wszystkie sekcje
    padding: [dp(15), dp(8), dp(15), dp(15)]
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: get_color_from_hex("#063e6e") # Główne tło karty
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

    # --- NAGŁÓWEK (Tytuł + Badge Statusu) ---
    FloatLayout:
        size_hint_y: None
        height: dp(32)

        Label:
            text: root.title
            bold: True
            font_size: '18sp'
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            size_hint: 1, None
            height: dp(32)
            x: self.parent.x
            y: self.parent.y

        Label:
            text: app.translate("my_subject_" + root.status, app.language)
            size_hint: None, None
            width: dp(95)
            height: dp(24)
            x: self.parent.right - self.width
            center_y: self.parent.center_y

            font_size: '12sp'
            halign: 'center'
            valign: 'middle'
            text_size: self.size
            color: (0, 0, 0, 1)

            canvas.before:
                Color:
                    rgba:
                        get_color_from_hex("#2ecc71") if root.status == "completed" else \
                        get_color_from_hex("#f1c40f") if root.status == "atrisk" else \
                        get_color_from_hex("#e74c3c")
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]

    # --- SUBTYTUŁ ---
    Label:
        text: root.teacher
        font_size: '13sp'
        color: (0.8, 0.8, 0.8, 1)
        halign: 'left'
        text_size: self.size
        size_hint_y: None
        height: dp(20)

    # --- KONTEJNER: NIEOBECNOŚCI ---
    BoxLayout:
        id: progress_container_wrapper
        orientation: 'vertical'
        padding: dp(10)
        spacing: dp(5)
        size_hint_y: None
        height: dp(60)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#1c4271")
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(8)]

        Label:
            text: app.translate("absences", app.language) + ": " + root.absences
            font_size: '12sp'
            bold: True
            halign: 'left'
            text_size: self.size

        BoxLayout:
            id: progress_container
            size_hint_y: None
            height: dp(15)

    # --- KONTEJNER: WARUNKI ZALICZENIA ---
    BoxLayout:
        orientation: 'vertical'
        padding: [dp(12), dp(10)]
        spacing: dp(4)
        size_hint_y: None
        height: dp(80)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#2d2d2d")
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [dp(5)]
        
        Label:
            text: app.translate("passing_conditions", app.language)
            font_size: '10sp'
            color: (0.7, 0.7, 0.7, 1)
            halign: 'left'
            text_size: self.size
            size_hint_y: None
            height: dp(15)
            
        ScrollView:
            size_hint_y: 1
            do_scroll_x: False
            do_scroll_y: True
            bar_width: dp(4)

            Label:
                text: root.rules if root.rules else app.translate("no_defined_conditions", app.language)
                font_size: '12sp'
                halign: 'left'
                valign: 'top'
                size_hint_y: None
                text_size: self.width, None
                height: max(self.texture_size[1], self.parent.height)

<RepozytoriumZasadScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(20)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#3b3232")
            Rectangle:
                pos: self.pos
                size: self.size

        Label:
            text: app.translate("rules_repository", app.language)
            font_size: '28sp'
            bold: True
            size_hint_y: None
            height: dp(50)
            text_size: self.size
            halign: 'left'

        ScrollView:
            GridLayout:
                id: rules_container
                cols: 2
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(20)
                padding: dp(10)