<CustomButtonWidget>:
    background_normal: ''
    background_color: (0, 0, 0, 0) 
    
    # Wyśrodkowanie tekstu
    halign: 'center'
    valign: 'middle'
    text_size: self.size

    canvas.before:
        Color:
            rgba: root.style.bg_color if root.style else [0.2, 0.2, 0.2, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8,] 

    # Kolor tekstu
    color: self.text_color

