<CustomButtonWidget>:
    background_color: (0, 0, 0, 0) 
    
    # Wyśrodkowanie tekstu
    halign: 'center'
    valign: 'middle'
    text_size: self.size

    canvas.before:
        Color:
            rgba: 
                (root.style.bg_color[0]*0.8, root.style.bg_color[1]*0.8, root.style.bg_color[2]*0.8, 1) \
                if self.state == 'down' else \
                (root.style.bg_color if root.style else [0.2, 0.2, 0.2, 1])
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8,] 

    # Kolor tekstu
    color: root.style.text_color if root.style else [1, 1, 1, 1]

<BrickWidget>:

    background_color: (0, 0, 0, 0) 
    
    # Wyśrodkowanie tekstu
    halign: 'center'
    valign: 'middle'
    text_size: self.size

    canvas.before:
        Color:
            rgba: root.style.bg_color if root.style else [0.2, 0.2, 0.2, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8,] 

    # Kolor tekstu
    color: root.style.text_color if root.style else [1, 1, 1, 1]