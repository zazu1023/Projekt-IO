#:import get_color_from_hex kivy.utils.get_color_from_hex
#:import ButtonStyle Style.ButtonStyle.ButtonStyle
#:import Shapes Style.ButtonShape.Shapes
<SidebarButton@Button>:
    size_hint_y: None
    height: 50

    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0

    color: app.styles.LIGHT_COLOR

    font_size: 15
    bold: True

    canvas.before:
        Color:
            rgba: app.styles.SIDE_BUTTON_ACTIVE_COLOR if self.state == "down" else app.styles.SIDE_BUTTON_COLOR
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [25]
    on_state:
        self.canvas.ask_update()

<CustomButtonBase>:
    background_color: (0, 0, 0, 0) 
    size_hint: None, None
    size: dp(150), dp(75)
    
    canvas.before:
        # Tło przycisku
        Color:
            rgba: root.style.get_bg_color(root.btn_state) if root.style else [0.2, 0.2, 0.2, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [root.style.border_radius] if root.style else [8]

        # Obramówka (Bezpieczna, z zabezpieczeniem przed awarią 0px)
        Color:
            rgba: root.style.get_border_color(root.btn_state) if root.style else [0, 0, 0, 0]
        Line:
            width: (dp(root.style.border_width) if (root.style and root.style.border_width > 0) else dp(1))
            rounded_rectangle: (self.x, self.y, self.width, self.height, (root.style.border_radius if root.style else 8))
            
    color: root.style.get_text_color(root.btn_state) if root.style else [1, 1, 1, 1]

<CustomButtonWidget>:
    Label:
        text: root.text if hasattr(root, 'text') else ''
        halign: 'center'
        valign: 'middle'
        text_size: self.size
        shorten: True
        shorten_from: 'right'
        color: root.style.get_text_color(root.btn_state) if root.style else [1, 1, 1, 1]


# =========================================================================
# 2. SEKCJA BRICK (Kafelki kalendarza / przedmiotów)
# =========================================================================
<BrickWidget>:
    background_normal: ''
    background_color: (0, 0, 0, 0)
    orientation: 'vertical'
    size_hint: None, None
    size: 180, 110
    padding: [15, 10, 5, 10]
    spacing: 2

    canvas.before:
        Color:
            rgba: root.style.get_bg_color(root.btn_state) if root.style else [0.2, 0.2, 0.2, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [root.style.border_radius] if root.style else [20]
            
        # Opcjonalna ramka wokół kafelka
        Color:
            rgba: root.style.get_border_color(root.btn_state) if root.style else [0, 0, 0, 0]
        Line:
            width: (dp(root.style.border_width) if (root.style and root.style.border_width > 0) else dp(1))
            rounded_rectangle: (self.x, self.y, self.width, self.height, (root.style.border_radius if root.style else 20))
            
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.6
        Label:
            text: root.title_text
            bold: True
            font_size: '18sp'
            color: root.style.get_text_color(root.btn_state) if root.style else [1, 1, 1, 1]
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Image:
            source: 'Images/notebook.png' 
            opacity: 1 if root.has_note else 0
            size_hint_x: None
            width: self.height
            allow_stretch: True
            keep_ratio: True
    Label:
        text: root.info_text
        size_hint_y: 0.4
        font_size: '14sp'
        color: root.style.get_text_color(root.btn_state) if root.style else [1, 1, 1, 0.8]
        halign: 'left'
        valign: 'bottom'
        text_size: self.size

# =========================================================================
# 3. KONKRETNE IMPLEMENTACJE STYLÓW
# =========================================================================
<BlueBrick@BrickWidget>:
    style: ButtonStyle(bg_color="2e588c", hover_bg_color="2e587c", text_color="#ffffff", border_radius=10, shape=Shapes.ROUNDED)

<BlueButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="2e588c", hover_bg_color="2e587c", text_color="#ffffff", border_radius=9, shape=Shapes.ROUNDED)
    size_hint_y: None
    height: dp(40)
    text_size: root.width, None

# =========================================================================
# 4. POPUP POWIADOMIEN (Dzwonek)
# =========================================================================
<NotificationPopup>:
    title: "Nadchodzące wydarzenia"
    title_align: 'center'
    size_hint: 0.8, 0.7 
    auto_dismiss: False
    background_color: 0.15, 0.15, 0.15, 1
    
    BoxLayout:
        orientation: 'vertical'
        padding: 10
        spacing: 15
        
        ScrollView:
            BoxLayout:
                id: events_container
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 10
                
        BlueButton:
            text: app.translate("btn_close", app.language)
            size_hint_y: None
            height: dp(50)
            size_hint_x: 1
            on_release: root.dismiss()