#:import get_color_from_hex kivy.utils.get_color_from_hex
<CustomButtonWidget>:
    background_color: (0, 0, 0, 0) 
    
    # Wyśrodkowanie tekstu
    halign: 'center'
    valign: 'middle'
    text_size: self.size
    size_hint: None , None
    size: 150 , 75
    canvas.before:
        Color:
            rgba: 
                (root.style.bg_color[0]*0.7, 
                root.style.bg_color[1]*0.7, 
                root.style.bg_color[2]*0.7, 1) \
                if (self.state == 'down') else \
                
               
                root.style.hover_bg_color \
                if (self.hovered ) else \
                
            
                root.style.bg_color if root.style else [0.2, 0.2, 0.2, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [root.style.border_radius] if root.style else [8,]

    # Kolor tekstu
    color: root.style.text_color if root.style else [1, 1, 1, 1]

<BrickWidget>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    orientation: 'vertical'
    size_hint: None, None
    size: 180, 110
    padding: [15, 10, 5, 10]
    spacing: 2

    canvas.before:
        Color:
            rgba: 
                (root.style.bg_color[0]*0.7, 
                root.style.bg_color[1]*0.7, 
                root.style.bg_color[2]*0.7, 1) \
                if (self.state == 'down' and self.has_note) else \
                
               
                root.style.hover_bg_color \
                if (self.hovered and self.has_note) else \
                
            
                root.style.bg_color if root.style else [0.2, 0.2, 0.2, 1]

        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [root.style.border_radius,] if root.style else [20,]

 
    BoxLayout:
        orientation: 'horizontal'
        size_hint_y: 0.6
        Label:
            text: root.title_text
            bold: True
            font_size: '18sp'
            halign: 'left'
            valign: 'middle'
            text_size: self.size
        Image:
           
            source: 'Images/notebook.png' 
            opacity: 1 if root.has_note else 0
            
            size_hint_x: None
            width: self.height # sprawia, że jest kwadratowy
            
            allow_stretch: True
            keep_ratio: True
    Label:
        text: root.info_text
        size_hint_y: 0.4
        font_size: '14sp'
        color: [1, 1, 1, 0.8]
        halign: 'left'
        valign: 'bottom'
        text_size: self.size

<BlueBrick@BrickWidget>:
    style: ButtonStyle(bg_color=get_color_from_hex("2e588c"),hover_bg_color=get_color_from_hex("2e587c") , text_color=[1,1,1,1], border_radius=10, shape=Shapes.ROUNDED)

<BlueButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color=get_color_from_hex("2e588c"),hover_bg_color=get_color_from_hex("2e587c") , text_color=[1,1,1,1], border_radius=15, shape=Shapes.ROUNDED)