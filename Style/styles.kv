#:import get_color_from_hex kivy.utils.get_color_from_hex
#:import ButtonStyle Widgets.Button.ButtonStyle
#:import Shapes Widgets.Button.Shapes
<SidebarButton@Button>:
    size_hint_y: None
    height: 50

    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0

    color: app.styles.LIGHT_COLOR

    font_size: 15
    bold: True

    canvas.before:
        Color:
            rgba: app.styles.SIDE_BUTTON_ACTIVE_COLOR if self.state == "down" else app.styles.SIDE_BUTTON_COLOR
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [25]
    on_state:
        self.canvas.ask_update()
<CustomButtonWidget>:
    background_color: (0, 0, 0, 0) 
    
    # Wyśrodkowanie tekstu
    halign: 'center'
    valign: 'middle'
    text_size: self.size
    size_hint: None , None
    size: 150 , 75
    canvas.before:
        Color:
            rgba: 
                (get_color_from_hex(root.style.bg_color)[0]*0.5, 
                get_color_from_hex(root.style.bg_color)[1]*0.5, 
                get_color_from_hex(root.style.bg_color)[2]*0.5, 1) \
                if (self.state == 'down') else \
                
            
                (get_color_from_hex(root.style.bg_color)[0]*0.8, 
                get_color_from_hex(root.style.bg_color)[1]*0.8, 
                get_color_from_hex(root.style.bg_color)[2]*0.8, 1) \
                if (self.hovered ) else \
                
            
                get_color_from_hex(root.style.bg_color) if root.style else [0.2, 0.2, 0.2, 1]
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [root.style.border_radius] if root.style else [8,]

    # Kolor tekstu
    color: root.style.text_color if root.style else [1, 1, 1, 1]

<BrickWidget>:
    background_normal: ''
    background_color: 0, 0, 0, 0
    orientation: 'vertical'
    size_hint: None, None
    size: 180, 110
    padding: [15, 10, 5, 10]
    spacing: 2

    canvas.before:
        Color:
            rgba: 
                (get_color_from_hex(root.style.bg_color)[0]*0.7, 
                get_color_from_hex(root.style.bg_color)[1]*0.7, 
                get_color_from_hex(root.style.bg_color)[2]*0.7, 1) \
                if (self.state == 'down' and self.has_note) else \
                
            
                root.style.hover_bg_color \
                if (self.hovered and self.has_note) else \
                
            
                root.style.bg_color if root.style else [0.2, 0.2, 0.2, 1]

        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [root.style.border_radius,] if root.style else [20,]


<BlueBrick@BrickWidget>:
    style: ButtonStyle(bg_color="2e588c",hover_bg_color="2e587c" , text_color=[1,1,1,1], border_radius=10, shape=Shapes.ROUNDED)

<BlueButton@CustomButtonWidget>:
    style: ButtonStyle(bg_color="2e588c",hover_bg_color="2e587c" , text_color=[1,1,1,1], border_radius=9, shape=Shapes.ROUNDED)
    size_hint_y: None
    height: dp(40)
    text_size: root.width, None