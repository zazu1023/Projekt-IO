#:import SessionPanel components.sideBar.SessionPanel
MainLayout:

# 2. DEFINICJA WYGLĄDU:
<MainLayout@BoxLayout>:
    orientation: 'vertical' # Układ góra-dół

    # ==========================================
    # GÓRNY PASEK (Biały, przez całą szerokość)
    # ==========================================
    BoxLayout:
        size_hint_y: None
        height: dp(80)
        padding: dp(5)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#f8f9fa") # Jasnoszare/białe tło
            Rectangle:
                pos: self.pos
                size: self.size

        # Obszar Logo (szerokość równa lewemu menu)
        BoxLayout:
            size_hint_x: None
            width: dp(220)
            padding: dp(5)
            # Tu wstawisz docelowo obrazek Image:
            Label:
                text: "[b]STUDENT[/b]\nPLANNER"
                markup: True
                color: get_color_from_hex("#1565c0")
                halign: 'left'

        # Środkowy tekst (Najbliższe...)
        Label:
            text: "Najbliższe: Brak nadchodzących kolokwiów/egzaminów"
            color: get_color_from_hex("#1565c0")
            bold: True

        # Prawa strona (Przyciski Ciemny motyw / Język)
        BoxLayout:
            size_hint_x: None
            width: dp(180)
            spacing: dp(10)
            padding: dp(10) , dp(10) , dp(10) , dp(20)

            CustomButtonWidget:
                style: ButtonStyle(bg_color="9ea6b3" , text_color=[0,0,0,1], border_radius=6, shape=Shapes.ROUNDED)
                text: "" 
                size_hint_x: None
                width: dp(40)
                height: dp(30)
                canvas.after:
                    Color:
                        rgba: 1, 1, 1, 1
                    Rectangle:
                        source: "Images/ikona_dzwonek.png"
                        size: dp(18), dp(18)
                        pos: self.center_x - dp(9), self.center_y - dp(9)
            CustomButtonWidget:
                style: ButtonStyle(bg_color="9ea6b3" , text_color=[0,0,0,1], border_radius=6, shape=Shapes.ROUNDED)
                text: "ANG" if app.language == "pl" else "PL"
                size_hint_x: None
                width: dp(120)
                height: dp(30)
                on_release: app.change_language()

    # ==========================================
    # DOLNA CZĘŚĆ (Menu po lewej + Ekrany po prawej)
    # ==========================================
    BoxLayout:
        orientation: 'horizontal'

        # --- LEWY PANEL (Ciemnoniebieski) ---
        BoxLayout:
            orientation: 'vertical'
            size_hint_x: None
            width: dp(180)
            padding: dp(10)
            spacing: dp(5)
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#0b3d91") # Ciemnoniebieski kolor z obrazka
                Rectangle:
                    pos: self.pos
                    size: self.size

            # Przyciski nawigacyjne
            BlueButton:
                text: app.translate("start_calendar", app.language)
                on_release: app.change_screen('calendar')
            BlueButton:
                text: app.translate("my_subjects_text", app.language)
                
                on_release: app.change_screen('mySubjects')
            BlueButton:
                text: app.translate("add_subject", app.language)
            BlueButton:
                text: app.translate("exams_tests", app.language)
                on_release: app.change_screen('exams_tests')
               
            BlueButton:
                text: app.translate("rules_repository", app.language)
            
            BlueButton:
                text: app.translate("progress_tracker", app.language)
            
            
            Widget: # Wypychacz, spycha Sesję na dół

            # Panel Sesji
            SessionPanel:
                id: countdown_box
                orientation: "vertical"
                size_hint_y: None
                height: 105
                padding: 10
                spacing: 4

                canvas.before:
                    Color:
                        rgba: (0.176, 0.345, 0.549, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [12]

                Label:
                    text: app.translations[app.language]["countdown_text"]
                    color: 1, 1, 1, 1
                    bold: True
                    font_size: 15
                    size_hint_y: None
                    height: 28
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

        # --- GŁÓWNY OBSZAR ROBOCZY (Ciemny) ---
        ScreenManager:
            id: sm
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#2c2c2e") # Ciemnoszare tło z prawej strony obrazka
                Rectangle:
                    pos: self.pos
                    size: self.size