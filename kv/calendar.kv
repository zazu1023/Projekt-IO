<CalendarWidget>:
    orientation: "vertical"
    padding: [30, 20, 30, 20] 
    spacing: 15

    Label:
        text: app.translations[app.language]["start_calendar"]
        font_size: '26sp'
        bold: True
        color: 1, 1, 1, 1
        size_hint_y: None
        height: 40
        halign: "left"
        valign: "middle"
        text_size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: 16
        spacing: 12

        canvas.before:
            Color:
                rgba: app.styles.NAV_COLOR
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

        Label:
            text: root.week_label
            size_hint_y: None
            height: 24
            color: 1, 1, 1, 1
            font_size: 14
            halign: "left"
            valign: "middle"
            text_size: self.size

        BoxLayout:
            size_hint_y: None
            height: 36
            spacing: 10

            Button:
                text: app.translations[app.language]["btn_prev"]
                size_hint_x: None
                width: 150
                on_release: root.previous_week()

            Button:
                text: app.translations[app.language]["btn_next"]
                size_hint_x: None
                width: 150
                on_release: root.next_week()

            Button:
                text: app.translations[app.language]["btn_current"]
                size_hint_x: None
                width: 220
                on_release: root.current_week()

            Button:
                text: app.translations[app.language]["btn_choose"]
                size_hint_x: None
                width: 190
                on_release: root.choose_week()

            Widget:

        BoxLayout:
            orientation: "horizontal"
            padding: 0
            spacing: 8

            canvas.before:
                Color:
                    rgba: app.styles.BG_COLOR
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]

            BoxLayout:
                id: days_box
                orientation: "horizontal"
                spacing: 8
                padding: 8

    BoxLayout:
        orientation: "vertical"
        size_hint_y: None
        height: 135
        padding: 16
        spacing: 8

        canvas.before:
            Color:
                rgba: app.styles.NAV_COLOR
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

        Label:
            text: app.translations[app.language]["upcoming"]
            size_hint_y: None
            height: 26
            color: 1, 1, 1, 1
            font_size: 16
            bold: True
            halign: "left"
            valign: "middle"
            text_size: self.size

        BoxLayout:
            id: upcoming_box
            orientation: "vertical"
            spacing: 2