#:import get_color_from_hex kivy.utils.get_color_from_hex

<CalendarNavButton@Button>:
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    font_size: 14
    bold: True
    
    # Zabezpieczenie przed wylewaniem się tekstu przy mocnym ściśnięciu okna
    text_size: self.width - 15, None
    halign: 'center'
    shorten: True
    shorten_from: 'right'

    canvas.before:
        Color:
            rgba: get_color_from_hex("#707070") if self.state == "down" else get_color_from_hex("#5e5e5e")
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [self.height / 2]

<CalendarWidget>:
    orientation: "vertical"
    padding: [30, 20, 30, 20] 
    spacing: 15

    Label:
        text: app.translate("start_calendar", app.language)
        font_size: '26sp'
        bold: True
        color: 1, 1, 1, 1
        size_hint_y: None
        height: 40
        halign: "left"
        valign: "middle"
        text_size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: 16
        spacing: 12

        canvas.before:
            Color:
                rgba: (0.10, 0.25, 0.45, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

        Label:
            text: root.week_label
            size_hint_y: None
            height: 30
            color: 1, 1, 1, 1
            font_size: 14
            halign: "left"
            valign: "middle"
            text_size: self.size

        # === ZMIANA: Max szerokość 740px, trzyma się lewej, kurczy przy zmniejszaniu ===
        BoxLayout:
            size_hint_x: None
            width: min(self.parent.width - 32, 740)
            size_hint_y: None
            height: 36
            spacing: 10

            CalendarNavButton:
                text: app.translate("btn_prev", app.language)
                size_hint_x: 1.5
                on_release: root.previous_week()

            CalendarNavButton:
                text: app.translate("btn_next", app.language)
                size_hint_x: 1.5
                on_release: root.next_week()

            CalendarNavButton:
                text: app.translate("btn_current", app.language)
                size_hint_x: 2.2
                on_release: root.current_week()

            CalendarNavButton:
                text: app.translate("btn_choose", app.language)
                size_hint_x: 1.9
                on_release: root.choose_week()
        # =========================================================================

        BoxLayout:
            orientation: "horizontal"
            padding: 0
            spacing: 8

            canvas.before:
                Color:
                    rgba: (0.196, 0.173, 0.169, 1)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]

            BoxLayout:
                id: days_box
                orientation: "horizontal"
                spacing: 8
                padding: 8

    BoxLayout:
        orientation: "vertical"
        size_hint_y: None
        height: 135
        padding: 16
        spacing: 8

        canvas.before:
            Color:
                rgba: (0.10, 0.25, 0.45, 1)
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

        Label:
            text: app.translate("upcoming", app.language)
            size_hint_y: None
            height: 26
            color: 1, 1, 1, 1
            font_size: 16
            bold: True
            halign: "left"
            valign: "middle"
            text_size: self.size

        BoxLayout:
            id: upcoming_box
            orientation: "vertical"
            spacing: 2