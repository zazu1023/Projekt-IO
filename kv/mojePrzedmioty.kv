#:import ButtonStyle Widgets.Button.ButtonStyle
#:import Shapes Widgets.Button.Shapes
#:import get_color_from_hex kivy.utils.get_color_from_hex

<DashboardBrick>:
    orientation: 'vertical'
    padding: dp(15)
    spacing: dp(5)
    
    # Ustawiamy sztywny rozmiar kafelka, żeby siatka wyglądała równo
    size_hint: 1 , None
    height: dp(120)
    on_release: app.change_screen('subjectDetails', selectedSubject=self.subject_obj)
    # 1. Tytuł (Pogrubiony)
    Label:
        text: root.subject_obj.title
        bold: True
        color: [0, 0, 0, 1] # Czarny tekst
        text_size: self.size
        halign: 'left'
        valign: 'top'

    # 2. Podtytuł (Zwykły)
    Label:
        text: root.subject_obj.teacher
        color: [0.1, 0.1, 0.1, 1]
        text_size: self.size
        halign: 'left'
        valign: 'middle'

    # 3. Status (Pogrubiony, mniejszy na dole)
    Label:
        text: root.subject_obj.status
        bold: True
        font_size: '12sp'
        color: [0, 0, 0, 1]
        text_size: self.size
        halign: 'left'
        valign: 'bottom'
<SubjectGreen@DashboardBrick>:
    status_text: app.translate('my_subject_completed' , app.language)
    style: ButtonStyle(bg_color="#62c57b",hover_bg_color="#2e587c" , text_color="000000", border_radius=10, shape=Shapes.ROUNDED)

<SubjectRed@DashboardBrick>:
    status_text: app.translate('my_subject_atrisk' , app.language)
    style: ButtonStyle(bg_color="#f28b82",hover_bg_color="#2e587c" , text_color="000000", border_radius=10, shape=Shapes.ROUNDED)

<SubjectWhite@DashboardBrick>:
    status_text: app.translate('my_subject_inprogress' , app.language)
    style: ButtonStyle(bg_color="#d9d9d7",hover_bg_color="#2e587c" , text_color="000000", border_radius=10, shape=Shapes.ROUNDED)
    
<MojePrzedmiotyScreen@Screen>
    BoxLayout:
        
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        
        # Ciemnoszare tło całej aplikacji (jak na screenie poza niebieskim obszarem)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#332b2b")
            Rectangle:
                pos: self.pos
                size: self.size

        # Nagłówek
        Label:
            text: "Moje przedmioty"
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: dp(40)
            text_size: self.size
            halign: 'left'
            valign: 'middle'

        # Niebieski kontener na kafelki
        BoxLayout:
            padding: dp(15)
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#1c4271") # Niebieskie tło
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10,]

            # Siatka, która automatycznie układa kafelki od lewej do prawej
            ScrollView:
                do_scroll_x: False

                GridLayout:
                    id: grid_przedmiotow
                    cols: 3 # Ilość kolumn (dostosuj do szerokości okna)
                    spacing: dp(15)
                    
                    # Ważne: to pozwala siatce rosnąć w dół, jeśli dodasz więcej kafelków
                    size_hint_y: None
                    height: self.minimum_height

                    # --- TUTAJ WRZUCASZ SWOJE KAFELKI ---
                    # To jest przykład statyczny. Docelowo wrzucisz je tu z Pythona
                    # lub przez podpięcie backendu, o którym rozmawialiśmy wcześniej.
                    
                   