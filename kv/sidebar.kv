<SideBar>:
    orientation: "vertical"
    size_hint_x: None
    width: 214
    padding: 16
    spacing: 20

    canvas.before:
        Color:
            rgba: app.styles.NAV_COLOR
        Rectangle:
            pos: self.pos
            size: self.size

    SidebarButton:
        text: app.translations[app.language]["start_calendar"]

    SidebarButton:
        text: app.translations[app.language]["my_subjects_text"]

    SidebarButton:
        text: app.translations[app.language]["add_subject"]

    SidebarButton:
        text: app.translations[app.language]["exams_tests"]

    SidebarButton:
        text: app.translations[app.language]["rules_repository"]

    SidebarButton:
        text: app.translations[app.language]["progress_tracker"]

    Widget:

    BoxLayout:
        id: countdown_box
        orientation: "vertical"
        size_hint_y: None
        height: 105
        padding: 10
        spacing: 4

        canvas.before:
            Color:
                rgba: app.styles.SIDE_BUTTON_COLOR
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [12]

        Label:
            text: app.translations[app.language]["countdown_text"]
            color: 1, 1, 1, 1
            bold: True
            font_size: 15
            size_hint_y: None
            height: 28
            halign: "left"
            valign: "middle"
            text_size: self.size

        BoxLayout:
            id: countdown_content
            orientation: "vertical"