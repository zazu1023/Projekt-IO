#:import get_color_from_hex kivy.utils.get_color_from_hex

# --- Kontrolki Plus/Minus ---
<PointControlRow>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(30)
    spacing: dp(10)
    
    Label:
        text: root.label_text
        color: 0, 0, 0, 1
        bold: True
        font_size: '13sp'
        size_hint_x: None
        width: dp(150) 
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        
    Label:
        text: root.value_text
        color: 0, 0, 0, 1
        bold: True
        size_hint_x: None
        width: dp(30)
        text_size: self.size
        halign: 'center'
        valign: 'middle'
        
    Button:
        text: "-"
        size_hint: None, None
        size: dp(40), dp(30)
        background_normal: ""
        background_down: ""
        background_color: 0,0,0,0
        color: 1, 1, 1, 1
        bold: True
        on_release: root.on_minus() # Podpięcie akcji
        canvas.before:
            Color:
                rgba: get_color_from_hex("#c94c4c") if self.state == 'normal' else get_color_from_hex("#a03a3a")
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [5]
                
    Button:
        text: "+"
        size_hint: None, None
        size: dp(40), dp(30)
        background_normal: ""
        background_down: ""
        background_color: 0,0,0,0
        color: 1, 1, 1, 1
        bold: True
        on_release: root.on_plus() # Podpięcie akcji
        canvas.before:
            Color:
                rgba: get_color_from_hex("#5cb85c") if self.state == 'normal' else get_color_from_hex("#469246")
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [5]
    
    Widget: 

# --- Główna Karta ---
<ProgressCard>:
    orientation: 'vertical'
    size_hint_y: None
    height: dp(225)
    padding: dp(15), dp(15), dp(15), dp(15)
    spacing: dp(8)
    
    canvas.before:
        Color:
            rgba: get_color_from_hex("#e0e0e0") 
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [15]
            
    Label:
        text: root.title_text
        color: 0, 0, 0, 1
        bold: True
        font_size: '18sp'
        size_hint_y: None
        height: dp(25)
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        
    Label:
        text: root.points_text
        color: 0.2, 0.2, 0.2, 1
        font_size: '14sp'
        size_hint_y: None
        height: dp(20)
        text_size: self.size
        halign: 'left'
        valign: 'middle'
        
    BoxLayout:
        id: progress_container
        size_hint_y: None
        height: dp(40)
        
    Widget:
        size_hint_y: None
        height: dp(5) 
        
    PointControlRow:
        label_text: "Plusy"
        # Automatycznie aktualizuje tekst na ekranie!
        value_text: str(root.pluses_val) 
        action_minus: lambda: root.change_pluses(-1)
        action_plus: lambda: root.change_pluses(1)
        
    PointControlRow:
        label_text: "Punkty za kolokwium"
        value_text: str(root.exam_val)
        action_minus: lambda: root.change_exam(-1)
        action_plus: lambda: root.change_exam(1)

# --- Główny Ekran ---
<TrackerProgresuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        
        Label:
            text: app.translate("progress_tracker", app.language) if hasattr(app, 'translate') else "Tracker progresu"
            font_size: '26sp'
            bold: True
            size_hint_y: None
            height: dp(40)
            text_size: self.size
            halign: 'left'
            valign: 'middle'
            color: 1, 1, 1, 1
            
        BoxLayout:
            padding: dp(15)
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#1c4271")
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]
                    
            ScrollView:
                do_scroll_x: False
                do_scroll_y: True
                bar_width: dp(6)
                bar_color: [0.6, 0.6, 0.6, 0.8]
                bar_inactive_color: [0.6, 0.6, 0.6, 0.4]
                scroll_type: ['content', 'bars']
                
                BoxLayout:
                    id: cards_container
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(15)
                    padding: [0, dp(10), dp(15), dp(20)]