
#:import get_color_from_hex kivy.utils.get_color_from_hex
#:import ButtonStyle Widgets.Button.ButtonStyle
#:import ButtonState Widgets.Button.ButtonState

<BaseButton@CustomButtonWidget>:
    size_hint: 1, 1 
    radius: [dp(10)]

<BackButton@BaseButton>:
    style: ButtonStyle(bg_color="#c0c2c4", text_color="#000000", border_radius=8)
    radius: [dp(8)]

<SuccessButton@BaseButton>:
    style: ButtonStyle(bg_color="#2ecc71", text_color="#000000", border_radius=15)
    radius: [dp(15)]

<WarningButton@BaseButton>:
    style: ButtonStyle(bg_color="#f1c40f", text_color="#000000", border_radius=15)
    radius: [dp(15)]

<DangerButton@BaseButton>:
    style: ButtonStyle(bg_color="#e74c3c", text_color="#000000", border_radius=15)
    radius: [dp(15)]

<PrimaryButton@BaseButton>:
    style: ButtonStyle(bg_color="#114c85", text_color="#ffffff", border_radius=10)

<MinusButton@BaseButton>:
    style: ButtonStyle(bg_color="#c0392b", text_color="#ffffff", border_radius=8)
    radius: [dp(8)]

<PlusButton@BaseButton>:
    style: ButtonStyle(bg_color="#2980b9", text_color="#ffffff", border_radius=8)
    radius: [dp(8)]

# ========================================================
# 2. SZABLON: Ciemne pole tekstowe
# ========================================================
<DarkRoundedInput@TextInput>:
    background_normal: ''
    background_color: get_color_from_hex("#322d2d") # Ciemne tło pola
    foreground_color: 1, 1, 1, 1 # Biały tekst
    cursor_color: 1, 1, 1, 1
    size_hint_y: None
    height: dp(35)
    multiline: False
    padding_y: [self.height / 2.0 - (self.line_height / 2.0), 0] # Wyśrodkowanie tekstu w pionie
# ========================================================
# 3. GŁÓWNY WIDOK EKRANU
# ========================================================
<SzczegolyPrzedmiotuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(20)
        canvas.before:
            Color:
                rgba: get_color_from_hex("#3b3232")
            Rectangle:
                pos: self.pos
                size: self.size

        # --- GÓRNY PASEK ---
        BoxLayout:
            orientation: 'vertical'  # Układa elementy jeden pod drugim
            size_hint_y: None
            height: dp(80)           # Zwiększona wysokość, bo mamy dwa wiersze
            spacing: dp(10)          # Odstęp między tytułem a przyciskiem
            
            Label:
                text: f"Szczegóły przedmiotu: {root.selectedSubject.title if root.selectedSubject else ''}"
                font_size: '28sp'    # Troszkę większa czcionka, jak na makiecie
                bold: True
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            BackButton:
                text: '<- Wróć'
                size_hint: None, None
                size: dp(90), dp(35)
                pos_hint: {'x': 0}   # Przykleja przycisk mocno do lewej krawędzi!
                on_release: app.go_back()

        # --- GŁÓWNA ZAWARTOŚĆ ---
        BoxLayout:
            spacing: dp(20)
            
            # --- LEWA KOLUMNA ---
            ScrollView:
                do_scroll_x: False
                size_hint_x: 0.5
                bar_width: dp(8)
                bar_color: get_color_from_hex("#888888")
                bar_inactive_color: get_color_from_hex("#666666")
                
                BoxLayout:
                    orientation: 'vertical'
                    spacing: dp(15)
                    size_hint_y: None
                    height: self.minimum_height
                    padding: [0, 0, dp(10), 0]
                    
                    # 1. PANEL STATUSU
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(135) # Lekko powiększony, by przyciski oddychały
                        padding: dp(15)
                        spacing: dp(10)
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#063e6e")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12)]
                                
                        Label:
                            text: "Aktualny status"
                            bold: True
                            size_hint_y: None
                            height: dp(20)
                            text_size: self.size
                            halign: 'left'
                            
                        Label:
                            text: app.translate('my_subject_' + root.selectedSubject.status) if root.selectedSubject else app.translate('my_subject_completed')
                            color: get_color_from_hex("#f1c40f") if root.selectedSubject and root.selectedSubject.status == 'inprogress' else (get_color_from_hex("#e74c3c") if root.selectedSubject and root.selectedSubject.status == 'atrisk' else get_color_from_hex("#2ecc71"))
                            bold: True
                            size_hint_y: None
                            height: dp(20)
                            text_size: self.size
                            halign: 'left'
                            
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(35) 
                            # Przyciski wypełnią tę przestrzeń, bo dostały size_hint: 1, 1
                            SuccessButton:
                                state: 'down' if root.selectedSubject and root.selectedSubject.status == self.text else 'normal'
                                text: app.translate('my_subject_completed')
                                on_release: root.change_status('completed')
                            WarningButton:
                                state: 'down' if root.selectedSubject and root.selectedSubject.status == self.text else 'normal'
                                text: app.translate('my_subject_inprogress')
                                on_release: root.change_status('inprogress')
                            DangerButton:
                                state: 'down' if root.selectedSubject and root.selectedSubject.status == self.text else 'normal'
                                text: app.translate('my_subject_atrisk')
                                on_release: root.change_status('atrisk')

                    # 2. PANEL NIEOBECNOŚCI
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(130)
                        padding: dp(15)
                        spacing: dp(10)
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#063e6e")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12)]
                                
                        Label:
                            text: "Nieobecności"
                            bold: True
                            size_hint_y: None
                            height: dp(20)
                            text_size: self.size
                            halign: 'left'
                            
                        Label:
                            
                            text: str(root.selectedSubject.absences) + "/" + str(root.selectedSubject.max_absences) if root.selectedSubject else "1/2"
                            font_size: '34sp'
                            bold: True
                            size_hint_y: None
                            height: dp(35)
                            text_size: self.size
                            halign: 'left'
                            
                        BoxLayout:
                            spacing: dp(10)
                            size_hint_y: None
                            height: dp(30) 
                            
                            MinusButton:
                                text: "-"
                                size_hint: None, 1
                                width: dp(40) # Kwadratowy mały przycisk
                                on_release: root.decrement_absences()
                            PlusButton:
                                text: "+"
                                size_hint: None, 1
                                width: dp(40) # Kwadratowy mały przycisk
                                on_release: root.increment_absences()
                            Widget: # Pychacz, żeby przyciski były do lewej krawędzi!

                    # 3. PANEL EDYCJI
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: dp(420) 
                        padding: dp(15)
                        spacing: dp(8) 
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#063e6e")
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(12)]
                                
                        Label:
                            text: "Edytuj przedmiot"
                            bold: True
                            size_hint_y: None
                            height: dp(30)
                            text_size: self.size
                            halign: 'left'
                            
                        # UWAGA: Usunięto bindowania "text: ...", zrobimy to w Pythonie
                        Label:
                            text: "Przedmiot"
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_title

                        Label:
                            text: "Prowadzący"
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_teacher
                        
                        Label:
                            text: "Warunki zaliczenia"
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_conditions

                        Label:
                            text: "Dopuszczalne nieobecności"
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_max_absences
                            
                        Label:
                            text: "Max liczba plusów"
                            size_hint_y: None
                            height: dp(15)
                            text_size: self.size
                            halign: 'left'
                        DarkRoundedInput:
                            id: input_max_pluses
                            
                        Widget: 

            # --- PRAWA KOLUMNA (Notatka) ---
            BoxLayout:
                orientation: 'vertical'
                padding: dp(15)
                spacing: dp(15)
                size_hint_x: 0.5
                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#063e6e")
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(12)]

                Label:
                    text: "Notatka ogólna"
                    bold: True
                    size_hint_y: None
                    height: dp(20)
                    text_size: self.size
                    halign: 'left'
                
                # UWAGA: Tu też usunięto bindowanie "text:"
                TextInput:
                    id: input_note
                    multiline: True
                    background_color: get_color_from_hex("#e0e0e0") # Jasnoszare tło z docelowego
                    text: root.selectedSubject.note if root.selectedSubject else ""
                    # on_text: if root.selectedSubject: root.selectedSubject.note = self.text
                    
                    
                PrimaryButton:
                    text: "Zapisz notatkę"
                    size_hint: 1, None # Wymuszamy pełną szerokość
                    height: dp(40)
                    on_release: 
                        if root.selectedSubject: root.selectedSubject.title = input_title.text
                        if root.selectedSubject: root.selectedSubject.teacher = input_teacher.text
                        if root.selectedSubject: root.selectedSubject.conditions = input_conditions.text
                        if root.selectedSubject: root.selectedSubject.note = input_note.text
                        print("Zapisano!")