<StartKalendarz>:
    BoxLayout:
        orientation: "vertical"

        canvas.before:
            Color:
                rgba: app.styles.BG_COLOR
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            size_hint_y: None
            height: 75
            padding: 20
            spacing: 20

            canvas.before:
                Color:
                    rgba: app.styles.TOP_BAR_COLOR
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: "SP"
                color: app.styles.NAV_COLOR
                font_size: 24
                bold: True
                size_hint_x: None
                width: 120

            Label:
                text: "Najbliższe: Brak nadchodzących kolokwiów/egzaminów"
                color: app.styles.NAV_COLOR
                font_size: 16
                bold: True

            Button:
                text: "ANG"
                size_hint_x: None
                width: 90

        BoxLayout:
            orientation: "horizontal"

            BoxLayout:
                orientation: "vertical"
                size_hint_x: None
                width: 214
                padding: 16
                spacing: 12

                canvas.before:
                    Color:
                        rgba: app.styles.NAV_COLOR
                    Rectangle:
                        pos: self.pos
                        size: self.size

                Button:
                    text: "Start / Kalendarz"
                    size_hint_y: None
                    height: 38

                Button:
                    text: "Moje przedmioty"
                    size_hint_y: None
                    height: 38

                Button:
                    text: "Dodaj przedmiot"
                    size_hint_y: None
                    height: 38

                Button:
                    text: "Egzaminy i kolokwia"
                    size_hint_y: None
                    height: 38

                Button:
                    text: "Repozytorium zasad"
                    size_hint_y: None
                    height: 38

                Button:
                    text: "Tracker progresu"
                    size_hint_y: None
                    height: 38

            BoxLayout:
                orientation: "vertical"
                padding: 26
                spacing: 18

                Label:
                    text: "Start / Kalendarz"
                    font_size: 28
                    bold: True
                    color: app.styles.LIGHT_COLOR
                    size_hint_y: None
                    height: 40
                    halign: "left"
                    text_size: self.size

                BoxLayout:
                    orientation: "horizontal"
                    spacing: 18

                    BoxLayout:
                        canvas.before:
                            Color:
                                rgba: app.styles.NAV_COLOR
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [8]

                    BoxLayout:
                        orientation: "vertical"
                        size_hint_x: None
                        width: 250
                        padding: 12
                        spacing: 12

                        canvas.before:
                            Color:
                                rgba: app.styles.ACCENT_COLOR
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [8]

                        Label:
                            text: "Notatki"
                            color: app.styles.LIGHT_COLOR
                            font_size: 18
                            bold: True
                            size_hint_y: None
                            height: 40

                        Label:
                            text: "Brak notatek"
                            color: app.styles.LIGHT_COLOR